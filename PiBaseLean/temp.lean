  meta_lindelof ι s s_open s_cover :=
    let ⟨β, t, β_open, t_cover, lct, ts⟩ := h.para_lindelof ι s s_open s_cover
    ⟨β, t, β_open, t_cover, LocallyCountable.pointCountable lct, ts⟩

