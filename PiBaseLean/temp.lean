  apply (hasOpenPathComponents_iff_ex_connected_nbhd X).mpr (fun x ↦ ?_)
  obtain ⟨s, sx, hs⟩ := h.simply_connected_nbhd x
  exact ⟨s, sx, IsSimplyConnected.isPathConnected hs⟩

