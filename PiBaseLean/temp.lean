/-- Theorem T160: P68 (RothbergerSpace) => P66 (MengerSpace) -/
instance instMengerSpaceOfRothbergerSpace (X : Type u)
    [TopologicalSpace X] [h : RothbergerSpace X] :
    MengerSpace X where
  menger := by
    intro ι U hU U_cover
    obtain ⟨j, hj⟩ := h.rothberger U hU U_cover

    --refine ⟨j, ?_⟩
    sorry

