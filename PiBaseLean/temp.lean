/-- Theorem T569: P21 (WeaklyCountablyCompact) => P198 (HasCountableExtent) -/
instance instHasCountableExtentOfWeaklyCountablyCompact (X : Type u)
    [TopologicalSpace X] [h : WeaklyCountablyCompact X] :
    HasCountableExtent X := by
  refine (hasCountableExtent_iff_discrete_countable X).mpr ?_
  intro s sd sc
  apply Finite.countable
  replace h := h.weakly_countably_compact
  contrapose! h
  refine ⟨s, h, ?_⟩
  intro x
  simp only [AccPt, not_neBot]
  refine inf_principal_eq_bot.mpr ?_
  refine mem_nhdsWithin.mpr ?_
  refine ⟨sᶜ, sc.isOpen_compl, ?_, inter_subset_left⟩

  sorry--nope

